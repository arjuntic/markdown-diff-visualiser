{
  "name": "markdown-diff-visualiser",
  "displayName": "Markdown Diff Visualiser",
  "description": "Rendered side-by-side preview of markdown file diffs within VS Code",
  "version": "0.0.1",
  "publisher": "arjuntic",
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "MIT",
  "categories": [
    "Visualization",
    "SCM Providers"
  ],
  "icon": "images/icon.png",
  "keywords": [
    "markdown",
    "diff",
    "preview",
    "git",
    "side-by-side",
    "rendered",
    "compare"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/arjuntic/markdown-diff-visualiser.git"
  },
  "homepage": "https://github.com/arjuntic/markdown-diff-visualiser#readme",
  "bugs": {
    "url": "https://github.com/arjuntic/markdown-diff-visualiser/issues"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownDiffVisualiser.showChanges",
        "title": "Markdown Diff Visualiser: Show Changes",
        "icon": {
          "light": "images/icon.svg",
          "dark": "images/icon.svg"
        }
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "markdownDiffVisualiser.showChanges",
          "when": "resourceLangId == markdown || resourceFilename =~ /\\.md$/ || resourceFilename =~ /\\.markdown$/",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "markdownDiffVisualiser.showChanges",
          "when": "resourceLangId == markdown || resourceFilename =~ /\\.md$/ || resourceFilename =~ /\\.markdown$/",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "markdownDiffVisualiser.showChanges",
          "when": "resourceFilename =~ /\\.md$/ || resourceFilename =~ /\\.markdown$/",
          "group": "navigation"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "markdownDiffVisualiser.showChanges",
          "when": "resourceFilename =~ /\\.md$/ || resourceFilename =~ /\\.markdown$/",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "package": "npm run bundle && npx @vscode/vsce package --allow-missing-repository",
    "test": "mocha --require ts-node/register 'src/test/**/*.test.ts' --timeout 10000",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "diff-match-patch": "^1.0.5",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "parse-diff": "^0.11.1"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chai": "^4.3.17",
    "@types/diff-match-patch": "^1.0.36",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.7",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.3",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "chai": "^4.4.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "fast-check": "^3.22.0",
    "mocha": "^10.7.0",
    "prettier": "^3.8.3",
    "proxyquire": "^2.1.3",
    "sinon": "^18.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.1"
  }
}
