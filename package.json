{
  "name": "markdown-diff-preview",
  "displayName": "Markdown Diff Preview",
  "description": "Rendered side-by-side preview of markdown file diffs within VS Code",
  "version": "0.0.1",
  "publisher": "markdown-diff-preview",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:markdownDiffPreview.showChanges"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownDiffPreview.showChanges",
        "title": "Markdown Diff Preview: Show Changes"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "markdownDiffPreview.showChanges",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "markdownDiffPreview.showChanges",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "markdownDiffPreview.showChanges",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "markdownDiffPreview.showChanges",
          "when": "resourceLangId == markdown",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "package": "npm run bundle && npx @vscode/vsce package --allow-missing-repository",
    "test": "mocha --require ts-node/register 'src/test/**/*.test.ts' --timeout 10000"
  },
  "dependencies": {
    "diff-match-patch": "^1.0.5",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "parse-diff": "^0.11.1"
  },
  "devDependencies": {
    "@types/chai": "^4.3.17",
    "@types/diff-match-patch": "^1.0.36",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.7",
    "@types/proxyquire": "^1.3.31",
    "@types/sinon": "^17.0.3",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "chai": "^4.4.1",
    "esbuild": "^0.28.0",
    "fast-check": "^3.22.0",
    "mocha": "^10.7.0",
    "proxyquire": "^2.1.3",
    "sinon": "^18.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
